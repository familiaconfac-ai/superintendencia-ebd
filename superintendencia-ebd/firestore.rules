rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAttendanceAdmin() {
      return request.auth != null
        && request.auth.token.email == "igrejabatistaolimpia@gmail.com";
    }

    match /users/{uid}/ebd_attendanceRegisters/{registerId} {
      allow read: if isAttendanceAdmin() || (request.auth != null && (
        request.auth.uid == uid ||
        resource.data.teacherUid == request.auth.uid ||
        resource.data.teacherAuthUid == request.auth.uid ||
        resource.data.teacherEmail == request.auth.token.email
      ));

      allow create: if isAttendanceAdmin() || (request.auth != null && (
        request.auth.uid == uid ||
        request.resource.data.teacherUid == request.auth.uid ||
        request.resource.data.teacherAuthUid == request.auth.uid ||
        request.resource.data.teacherEmail == request.auth.token.email
      ));

      allow update: if isAttendanceAdmin() || (request.auth != null && (
        request.auth.uid == uid ||
        resource.data.teacherUid == request.auth.uid ||
        resource.data.teacherAuthUid == request.auth.uid ||
        resource.data.teacherEmail == request.auth.token.email ||
        request.resource.data.teacherUid == request.auth.uid ||
        request.resource.data.teacherAuthUid == request.auth.uid ||
        request.resource.data.teacherEmail == request.auth.token.email
      ));

      allow delete: if isAttendanceAdmin() || (request.auth != null && request.auth.uid == uid);
    }

    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == "lPElyxdVK7dNAHUzvSK6w80qGls2";
    }

    match /cadernetas/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /presencas/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
